NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/auth_api

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Razorpay Payment Integration
# Get these from https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
# RazorpayX business account number (Dashboard → My Account → Account details)
RAZORPAY_ACCOUNT_NUMBER=your_razorpayx_account_number
